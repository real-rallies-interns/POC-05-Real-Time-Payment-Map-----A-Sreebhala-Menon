                  <div className="flex items-center gap-2 mb-2">
                    <div className="w-1.5 h-1.5 rounded-full" style={{ background:C.amber }}/>
                    <span className="text-xs font-bold tracking-widest" style={{ color:C.amber }}>ISO 20022 AS MOAT</span>
                  </div>
                  <p className="text-xs text-slate-400 leading-relaxed">
                    Countries that adopted ISO 20022 early can plug into SWIFT's cross-border network, enabling true rail-to-rail interoperability. This is the next competitive frontier — not domestic speed, but <span style={{ color:C.amber }}>global reach</span>.
                  </p>
                  <div className="mt-3 grid grid-cols-2 gap-2 text-xs">
                    {[
                      ["NEXUS (BIS)", "UPI ↔ PayNow", C.cyan],
                      ["TIPS (ECB)", "SEPA interop", C.indigo],
                      ["SWIFT GPI", "Cross-border", C.rose],
                      ["RTP + FedNow", "US dual-rail", C.emerald],
                    ].map(([k,v,c]) => (
                      <div key={k} className="bg-slate-900/60 rounded p-2 border border-slate-800">
                        <div style={{ color:c }} className="font-bold">{k}</div>
                        <div className="text-slate-500">{v}</div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            )}

            {/* Download */}
            <button onClick={handleDownload}
              className="w-full text-xs py-2.5 rounded-lg border transition-all"
              style={{ color:C.cyan, borderColor:`${C.cyan}40`, background:`${C.cyan}08` }}
              onMouseEnter={e=>e.currentTarget.style.boxShadow=`0 0 12px ${C.cyan}30`}
              onMouseLeave={e=>e.currentTarget.style.boxShadow="none"}>
              ↓ Export Filtered Data (JSON)
            </button>

            <div className="text-xs text-slate-700 text-center leading-relaxed pb-2">
              Sources: FedNow · EPC · World Bank · BIS<br/>
              Real Rails Intelligence · PoC #05 · Phase 2
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
