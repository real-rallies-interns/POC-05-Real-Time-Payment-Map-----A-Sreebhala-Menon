// ─── WORLD MAP VIEW ───────────────────────────────────────────────────────────
function MapView({ schemes, selected, onSelect, yearRange }) {
  const W = 820, H = 390;
  const gridLines = [];
  for (let lon = -180; lon <= 180; lon += 30) {
    const { x } = latLngToXY(0, lon, W, H);
    gridLines.push(<line key={`v${lon}`} x1={x} y1={0} x2={x} y2={H} stroke="#0F1A2A" strokeWidth="0.5"/>);
  }
  for (let lat = -60; lat <= 80; lat += 30) {
    const { y } = latLngToXY(lat, 0, W, H);
    gridLines.push(<line key={`h${lat}`} x1={0} y1={y} x2={W} y2={y} stroke="#0F1A2A" strokeWidth="0.5"/>);
  }

  return (
    <svg viewBox={`0 0 ${W} ${H}`} className="w-full h-full">
      <defs>
        {Object.entries(MATURITY_META).map(([k, v]) => (
          <radialGradient key={k} id={`mg-${k}`} cx="50%" cy="50%" r="50%">
            <stop offset="0%" stopColor={v.color} stopOpacity="0.95"/>
            <stop offset="100%" stopColor={v.color} stopOpacity="0.1"/>
          </radialGradient>
        ))}
        <filter id="mglow"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        <pattern id="dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="0.5" fill="#0D1B2A"/>
        </pattern>
      </defs>
      <rect width={W} height={H} fill="#040C18"/>
      <rect width={W} height={H} fill="url(#dots)"/>
      {gridLines}
      {(() => { const { y } = latLngToXY(0, 0, W, H); return <line x1={0} y1={y} x2={W} y2={y} stroke="#38BDF815" strokeWidth="1"/>; })()}

      {schemes.map(s => {
        const { x, y } = latLngToXY(s.lat, s.lng, W, H);
        const cfg = MATURITY_META[s.maturity];
        const inRange = s.launch_year >= yearRange[0] && s.launch_year <= yearRange[1];
        const isSel = selected?.code === s.code;
        const r = Math.min(14, 4 + Math.log10((s.daily_volume_m || 0.1) + 1) * 5);
        const op = inRange ? 1 : 0.12;
        return (
          <g key={s.code} onClick={() => onSelect(s.code === selected?.code ? null : s)} style={{ cursor: "pointer", opacity: op }}>
            {isSel && <circle cx={x} cy={y} r={r + 10} fill="none" stroke={cfg.color} strokeWidth="1.5" opacity="0.4">
              <animate attributeName="r" values={`${r+8};${r+18};${r+8}`} dur="2s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.05;0.5" dur="2s" repeatCount="indefinite"/>
            </circle>}
            <circle cx={x} cy={y} r={r + 5} fill={cfg.color} opacity="0.06"/>
            <circle cx={x} cy={y} r={r} fill={`url(#mg-${s.maturity})`}
              filter={isSel ? "url(#mglow)" : undefined}
              stroke={isSel ? cfg.color : "none"} strokeWidth="1.5"/>
            {inRange && <text x={x} y={y - r - 5} textAnchor="middle" fontSize="7.5" fill={`${cfg.color}CC`} fontFamily="monospace">{s.code}</text>}
          </g>
        );
      })}
    </svg>
  );
}

// ─── BENCHMARK BARS ───────────────────────────────────────────────────────────
function BenchmarkChart({ schemes, metric, label }) {
  const sorted = [...schemes].sort((a, b) => (b[metric] || 0) - (a[metric] || 0)).slice(0, 10);
  const max = sorted[0]?.[metric] || 1;
  return (
    <div className="space-y-1.5">
      {sorted.map(s => {
        const val = s[metric] || 0;
        const pct = (val / max) * 100;
        const color = MATURITY_META[s.maturity].color;
        return (
          <div key={s.code}>
            <div className="flex justify-between text-xs mb-0.5">
              <span className="text-slate-300 font-mono">{s.code} <span className="text-slate-600">{s.scheme}</span></span>
              <span className="font-mono" style={{ color }}>{metric === "daily_volume_m" ? (val >= 1 ? `${val}M` : `${(val * 1000).toFixed(0)}K`) : val || "—"}</span>
            </div>
            <div className="h-1.5 rounded-full bg-slate-800 overflow-hidden">
              <div className="h-full rounded-full transition-all duration-500" style={{ width: `${pct}%`, background: color }}/>
            </div>
          </div>
        );
      })}
      <div className="text-xs text-slate-700 text-right mt-1">{label}</div>
    </div>
  );
}

// ─── TIME SLIDER ──────────────────────────────────────────────────────────────
function TimeSlider({ yearRange, onChange }) {
  const trackRef = useRef(null);
  const byYear = {};
  SCHEMES.forEach(s => { byYear[s.launch_year] = (byYear[s.launch_year] || 0) + 1; });
  const cumulative = {};
  let running = 0;
  TIMELINE_YEARS.forEach(y => { running += (byYear[y] || 0); cumulative[y] = running; });
  const maxCum = running;

  const handleTrackClick = (e, isEnd) => {
    if (!trackRef.current) return;
    const rect = trackRef.current.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    const year = Math.round(2004 + pct * (2023 - 2004));
    if (isEnd) onChange([yearRange[0], Math.max(yearRange[0], year)]);
    else onChange([Math.min(year, yearRange[1]), yearRange[1]]);
  };

  const pctStart = ((yearRange[0] - 2004) / 19) * 100;
  const pctEnd = ((yearRange[1] - 2004) / 19) * 100;

  return (
    <div className="px-2">
      {/* Year bar chart */}
      <div className="flex items-end gap-px h-10 mb-2">
        {TIMELINE_YEARS.map(yr => {
          const count = byYear[yr] || 0;
          const inRange = yr >= yearRange[0] && yr <= yearRange[1];
          const h = count ? Math.max(4, (count / 4) * 32) : 2;
          return (
            <div key={yr} className="flex-1 flex flex-col items-center justify-end cursor-pointer"
              onClick={() => onChange([yr, yr])}>
              <div className="w-full rounded-t-sm transition-all duration-200"
                style={{
                  height: `${h}px`,
                  background: inRange ? (count > 2 ? C.cyan : count > 1 ? C.indigo : C.emerald) : "#1F2937",
                  opacity: inRange ? 1 : 0.3,
                }}/>
            </div>
          );
        })}
      </div>

      {/* Range track */}
      <div ref={trackRef} className="relative h-4 flex items-center cursor-pointer"
        onClick={e => {
          const rect = trackRef.current.getBoundingClientRect();
          const pct = (e.clientX - rect.left) / rect.width;
          const year = Math.round(2004 + pct * 19);
          const dStart = Math.abs(year - yearRange[0]);
          const dEnd = Math.abs(year - yearRange[1]);
          if (dStart < dEnd) onChange([Math.min(year, yearRange[1]), yearRange[1]]);
          else onChange([yearRange[0], Math.max(yearRange[0], year)]);
        }}>
        <div className="absolute inset-x-0 h-1 bg-slate-800 rounded-full"/>
        <div className="absolute h-1 rounded-full" style={{ left:`${pctStart}%`, right:`${100-pctEnd}%`, background:`linear-gradient(90deg, ${C.indigo}, ${C.cyan})` }}/>
        {[0, 1].map(i => (
          <div key={i} className="absolute w-3 h-3 rounded-full border-2 cursor-grab z-10"
            style={{ left:`${i === 0 ? pctStart : pctEnd}%`, transform:"translateX(-50%)", background:C.bg, borderColor: i===0?C.indigo:C.cyan, boxShadow:`0 0 8px ${i===0?C.indigo:C.cyan}60` }}
            onMouseDown={e => {
              e.preventDefault();
              const move = ev => {
                if (!trackRef.current) return;
                const rect = trackRef.current.getBoundingClientRect();
                const pct = Math.max(0, Math.min(1, (ev.clientX - rect.left) / rect.width));
                const year = Math.round(2004 + pct * 19);
                if (i === 0) onChange([Math.min(year, yearRange[1]), yearRange[1]]);
                else onChange([yearRange[0], Math.max(yearRange[0], year)]);
              };
              const up = () => { window.removeEventListener("mousemove", move); window.removeEventListener("mouseup", up); };
              window.addEventListener("mousemove", move); window.addEventListener("mouseup", up);
            }}/>
        ))}
      </div>

      {/* Labels */}
      <div className="flex justify-between text-xs font-mono mt-1">
        {[2004, 2008, 2012, 2016, 2020, 2023].map(y => (
          <span key={y} style={{ color: y >= yearRange[0] && y <= yearRange[1] ? C.cyan : C.slate6 }}>{y}</span>
        ))}
      </div>

      {/* Active range label */}
      <div className="flex items-center justify-center gap-2 mt-2">
        <span className="text-xs font-mono px-3 py-1 rounded-lg" style={{ color:C.indigo, background:`${C.indigo}15`, border:`1px solid ${C.indigo}30` }}>{yearRange[0]}</span>
        <span className="text-slate-600 text-xs">→</span>
        <span className="text-xs font-mono px-3 py-1 rounded-lg" style={{ color:C.cyan, background:`${C.cyan}15`, border:`1px solid ${C.cyan}30` }}>{yearRange[1]}</span>
        <span className="text-slate-500 text-xs ml-2">
          {SCHEMES.filter(s => s.launch_year >= yearRange[0] && s.launch_year <= yearRange[1]).length} rails active
        </span>
      </div>
    </div>
  );
}

