STATS = {
    "total_countries": len(RTP_SCHEMES),
    "leaders": sum(1 for c in RTP_SCHEMES if c["maturity"] == "Leader"),
    "established": sum(1 for c in RTP_SCHEMES if c["maturity"] == "Established"),
    "developing": sum(1 for c in RTP_SCHEMES if c["maturity"] == "Developing"),
    "iso20022_adopted": sum(1 for c in RTP_SCHEMES if c["iso20022"]),
    "earliest_launch": min(c["launch_year"] for c in RTP_SCHEMES),
    "latest_launch": max(c["launch_year"] for c in RTP_SCHEMES),
}

@app.get("/api/schemes")
def get_all_schemes():
    return {"data": RTP_SCHEMES, "meta": STATS}

@app.get("/api/schemes/{country_code}")
def get_scheme(country_code: str):
    match = next((c for c in RTP_SCHEMES if c["code"].upper() == country_code.upper()), None)
    if not match:
        return JSONResponse(status_code=404, content={"error": "Country not found or status unknown"})
    return match

@app.get("/api/timeline")
def get_timeline():
    by_year = {}
    for s in RTP_SCHEMES:
        yr = str(s["launch_year"])
        by_year.setdefault(yr, []).append({"code": s["code"], "name": s["name"], "scheme": s["scheme"]})
    return {"timeline": dict(sorted(by_year.items()))}

@app.get("/api/stats")
def get_stats():
    return STATS

@app.get("/api/download-sample")
def download_sample():
    sample = RTP_SCHEMES[:5]
    return {"sample_data": sample, "note": "Sample of 5 records. Full dataset available via /api/schemes"}
